#!/usr/bin/env python

import matplotlib.pyplot as plt
import shapely.plotting
from shapely.geometry import Polygon

class SVG:

  VERBOSE    = False
  ADD_POINTS = False

  def draw(self, b):

    fig, ax = plt.subplots() 
    ax.set_aspect('equal')    # make x and y axis the same
    print(f"0 {b.BLOCKSZ[0] * b.CLEN} 0 {b.BLOCKSZ[1] * b.CLEN}")
    plt.axis([0, (b.BLOCKSZ[0] * b.CLEN), 0, (b.BLOCKSZ[1] * b.CLEN)])

    for z in range(3): # bg 0 fg 1 top 2
      for pos, c in b.cells.items():

        if z == 2 and len(c.interiors) > 1: 
          lring = c.interiors[1]                   # top
        elif z == 2: continue 
        elif z == 1: lring = c.interiors[0]        # fg
        elif z == 0: lring = c.exterior            # bg

        if self.VERBOSE:
          print(f"{z} {pos} {len(c.interiors)} {b.style.fill[pos]}")
        
        shapely.plotting.plot_polygon(
          Polygon(lring), ax=ax, add_points=self.ADD_POINTS,
          facecolor=b.style.fill[pos][z],
          edgecolor=b.style.stroke[pos][z], 
          linewidth=b.style.stroke_width[pos][z]
        )
    plt.savefig(f"tmp/not_bft.svg", format="svg")

class Block:

  BLOCKSZ = (3, 1)
  CLEN    = 6

  def __init__(self): 
    self.cells = dict()
    self.style = Styles()

  def walk(self, positions, cells):
    ''' navigate the model and populate cells
    '''
    for pos in positions:
      cell = Cells(clen=self.CLEN, pos=pos)
      cell.background()
      label = positions[pos][0]
      self.style.add(pos, fill=cells[label]['bg'])

      for label in positions[pos]:
        if not label: continue
        if bool(cells[label]['top']):
          cell.foreground(
            shape  = cells[label]['shape'],
            facing = cells[label]['facing'],
            size   = cells[label]['size']
          )
          self.style.add(pos, fill=cells[label]['fill'])
        else:
          cell.foreground(
            shape  = cells[label]['shape'],
            facing = cells[label]['facing'],
            size   = cells[label]['size']
          )
          self.style.add(pos, fill=cells[label]['fill'])
      self.cells[pos] = cell.polygon()

  def meander(self):
    ''' transform polygons into lines
    for pos, c in self.cells.items():
      print(pos)
      print(c)
    '''
    print(self.cells[(0,0)].exterior)
    
class Cells:

  VERBOSE = False

  def __init__(self, pos=tuple([0,0]), clen=60): 
    self.bft   = list()
    self.clen  = clen     # length of cell
    self.pos   = pos      # logical position in block
  def background(self): 
    x = self.pos[0] * self.clen
    y = self.pos[1] * self.clen
    w = x + self.clen # a square has same width and height 
    h = y + self.clen
    self.bft.append(((x, y), (x, h), (w, h), (w, y)))
  def foreground(self, **kwargs):
    coords = self.rectangle(kwargs)
    if len(coords): self.bft.append(coords)
  def polygon(self):
    if len(self.bft) == 3:
      p = Polygon(self.bft[0], holes=[self.bft[1], self.bft[2]])
    else:             # must be two right ?
      p = Polygon(self.bft[0], holes=[self.bft[1]])
    return p

  # Shapes.shape.Rectangle()
  def rectangle(self, kwargs):
    shape = kwargs['shape']
    size  = kwargs['size']
    facing= kwargs['facing']
    sizes = { 
      'square': {
        'small': [
          self.pos[0] * self.clen + self.clen / 3,
          self.pos[1] * self.clen + self.clen / 3,
          self.pos[0] * self.clen + (self.clen / 3) * 2,
          self.pos[1] * self.clen + (self.clen / 3) * 2
        ],
        'medium': [
          self.pos[0] * self.clen,
          self.pos[1] * self.clen,
          self.pos[0] * self.clen + self.clen,
          self.pos[1] * self.clen + self.clen
        ]
      },
      'line': {
        'medium': {
          'north': [
            self.pos[0] * self.clen + self.clen / 3,
            self.pos[1] * self.clen,
            self.pos[0] * self.clen + (self.clen / 3) * 2,
            self.pos[1] * self.clen + self.clen
          ]
        },
        'large': {
          'east': [  # TODO
            self.pos[0] * self.clen - self.clen / 3,
            self.pos[1] * self.clen + self.clen / 3,
            self.pos[0] * self.clen + (self.clen / 3) * 4,
            self.pos[1] * self.clen + (self.clen / 3) * 2
          ]
        }
      }
    }
    if shape in sizes and size in sizes[shape]:
      if shape == 'square':
        x, y, w, h = sizes[shape][size]
      elif facing in sizes[shape][size]:
        x, y, w, h = sizes[shape][size][facing]
      else:
        raise NotImplementedError(f'{shape=} {size=} {facing=}')
    else: 
      raise NotImplementedError(f'{shape=} {size=}')

    if self.VERBOSE: print(f'{shape=} {size=} {facing=} {x} {y} {w} {h}')
    return ((x, y), (x, h), (w, h), (w, y))

class Styles:

  def __init__(self):
    self.fill             = dict()
    self.fill_opacity     = dict()
    self.stroke           = dict()
    self.stroke_dasharray = dict()
    self.stroke_opacity   = dict()
    self.stroke_width     = dict()

  def add(
    self, pos, fill=str(), fill_opacity=1, 
    stroke=None, stroke_opacity=0, stroke_dasharray=0, stroke_width=0
  ):
    ''' style.fill[(1,0)] = [
      'brown',  # bg
      'blue',   # fg
      'green'   # top
    ]

        initialise the attributes we need
    '''
    if pos not in self.fill:             self.fill[pos]             = []
    if pos not in self.fill_opacity:     self.fill_opacity[pos]     = []
    if pos not in self.stroke:           self.stroke[pos]           = []
    if pos not in self.stroke_dasharray: self.stroke_dasharray[pos] = []
    if pos not in self.stroke_opacity:   self.stroke_opacity[pos]   = []
    if pos not in self.stroke_width:     self.stroke_width[pos]     = []
    ''' assign values
    '''
    stroke = stroke if stroke else fill # make a non-stroke invisible

    self.fill[pos].append(fill)
    self.fill_opacity[pos].append(fill_opacity)
    self.stroke[pos].append(stroke)
    self.stroke_dasharray[pos].append(stroke_dasharray)
    self.stroke_opacity[pos].append(stroke_opacity)
    self.stroke_width[pos].append(stroke_width)

