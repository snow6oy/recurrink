    'help':'palette version',
    'type':int, 'choices':range(0, 99), 'metavar':'[0-99]'
  }
  arg_x = {
    'help':'exchange colours to -p as new svg',
    'action':argparse.BooleanOptionalAction
  }
  arg_z = {
    'help':'numof layers *3 or 2', 
