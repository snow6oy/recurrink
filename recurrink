  parser_k.add_argument('-p', '--penam',    **arg_p)

  parser_e.add_argument('-s', '--size',     **arg_s)
  parser_e.add_argument('-f', '--factor',   **arg_f)
  parser_e.add_argument('-l', '--line',     **arg_l)
